{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MXB App",
  "version": "0.1.1",
  "identifier": "com.frost.mxbikes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MXB App",
        "width": 1400,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Frostn1/mxb-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDRjEwQjlFQjhBQ0REOTQKUldTVTNheTRuZ3Z4ZklVZmltc3lLdWJtMUoxOUlycGhmbUJOL0JGMW5tMjlwblZtZzNaa2JGdVIK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English"]
      }
    }
  }
}
